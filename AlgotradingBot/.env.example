# Environment Configuration Example
# Copy this file to .env and update with your actual values
# SECURITY: Never commit .env file to version control

# ============================================
# PostgreSQL Database Configuration
# ============================================

# Database name
POSTGRES_DB=algotrading

# Database username
POSTGRES_USER=postgres

# Database password
# SECURITY: Change this in production! Use strong passwords (16+ chars, mixed case, numbers, symbols)
POSTGRES_PASSWORD=postgres123

# ============================================
# Spring Application Database Configuration
# ============================================

# Database connection URL
# Format: jdbc:postgresql://[host]:[port]/[database]
# For Docker: use service name as host (postgres)
# For local: use localhost
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/algotrading

# Database username (should match POSTGRES_USER)
SPRING_DATASOURCE_USERNAME=postgres

# Database password (should match POSTGRES_PASSWORD)
# SECURITY: Change this in production!
SPRING_DATASOURCE_PASSWORD=postgres123

# Runtime schema mode. The default application value is `validate`.
# Override only when you are doing an explicit schema migration or recovery workflow.
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# ============================================
# JVM Configuration
# ============================================

# Java runtime options
# -Xms: Initial heap size
# -Xmx: Maximum heap size
# -XX:MaxMetaspaceSize: Maximum metaspace size
JAVA_OPTS=-Xms512m -Xmx2g -XX:+UseZGC -XX:+ZGenerational -XX:MaxMetaspaceSize=512m -XX:+HeapDumpOnOutOfMemoryError

# Optional Docker backend debug options. Leave blank unless you intentionally want JDWP enabled.
JAVA_DEBUG_OPTS=

# Optional: tune the JDK virtual-thread scheduler parallelism explicitly.
# Leave blank to use the JDK default (available processors).
ALGOTRADING_VIRTUAL_THREAD_SCHEDULER_PARALLELISM=

# ============================================
# Trading Configuration
# ============================================

# Initial account balance in USDT
# Phase 1: $100-$500
INITIAL_BALANCE=100.00

# Risk per trade as percentage (0.02 = 2%)
# CRITICAL: Do not exceed 2% for capital preservation
RISK_PER_TRADE=0.02

# Maximum drawdown limit as percentage (0.25 = 25%)
# Circuit breaker triggers if exceeded
MAX_DRAWDOWN=0.25

# ============================================
# Historical Market Data Providers (Optional)
# ============================================

# Free-key providers for the Market Data downloader tab.
# Leave blank to disable those providers until you create a free account.
# Optional: backend master key used to encrypt provider API keys saved from the frontend into PostgreSQL.
# Set this before using Settings > API Config > Market Data Provider Credentials.
ALGOTRADING_MARKET_DATA_CREDENTIALS_MASTER_KEY=
ALGOTRADING_MARKET_DATA_TWELVEDATA_API_KEY=
ALGOTRADING_MARKET_DATA_FINNHUB_API_KEY=
ALGOTRADING_MARKET_DATA_ALPHAVANTAGE_API_KEY=

# ============================================
# Instructions
# ============================================

# 1. Copy this file:
#    cp .env.example .env
#
# 2. Update values in .env with your configuration
#
# 3. Verify .env is in .gitignore (it should be by default)
#
# 4. For production deployment:
#    - Change all passwords to strong, unique values
#    - Use secrets management (Docker secrets, Vault, etc.)
#    - Restrict database access to application only
#    - Enable TLS for database connections
#    - Review and adjust JVM memory settings based on load
#
# 5. For local development:
#    - Default values should work out of the box
#    - Adjust INITIAL_BALANCE for testing different scenarios
#    - Keep RISK_PER_TRADE at 0.02 (2%) for realistic testing

# ============================================
# Security Notes
# ============================================

# PASSWORDS:
# - Use strong passwords (16+ characters)
# - Mix uppercase, lowercase, numbers, symbols
# - Never reuse passwords across environments
# - Rotate passwords regularly (every 90 days)
# - Use password manager or secrets vault

# SENSITIVE DATA:
# - Never commit .env file to version control
# - Never log passwords or sensitive values
# - Use environment-specific .env files
# - Restrict file permissions: chmod 600 .env

# PRODUCTION CHECKLIST:
# - [ ] All passwords changed from defaults
# - [ ] Secrets stored in secure vault
# - [ ] Database access restricted by IP
# - [ ] TLS enabled for all connections
# - [ ] Environment variables validated
# - [ ] Backup encryption configured
