# API Configuration
# Backend REST API base URL
VITE_API_BASE_URL=http://localhost:8080

# WebSocket connection URL for real-time updates
VITE_WS_URL=ws://localhost:8080/ws

# Environment
# DEV, PROD, MODE are automatically set by Vite based on the build command
# - npm run dev → development mode
# - npm run build → production mode

# Notes:
# 1. Copy this file to .env for local development
# 2. Update .env.production for production deployment
# 3. Never commit .env files with sensitive data to version control
# 4. All environment variables must be prefixed with VITE_ to be exposed to the client
