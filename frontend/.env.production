# Production API Configuration
# These values should be overridden by environment variables in production deployment

# Backend API URL - Update this to your production backend URL
VITE_API_BASE_URL=https://api.yourdomain.com

# WebSocket URL - Update this to your production WebSocket URL
VITE_WS_URL=wss://api.yourdomain.com/ws

# Environment mode (automatically set by Vite)
# VITE_MODE=production
